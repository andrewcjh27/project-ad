# Copy to `.env` and fill in to enable real models. Never commit `.env`.
# Set ONE image/LLM provider (the code auto-detects which key is present).

# OpenAI — powers both the image model (gpt-image-1) and the LLM agents (gpt-4o-mini)
OPENAI_API_KEY=

# Anthropic — alternative LLM backend for the Art Director / Copywriter
ANTHROPIC_API_KEY=

# Replicate — alternative image backend (Flux 1.1 Pro)
REPLICATE_API_TOKEN=
